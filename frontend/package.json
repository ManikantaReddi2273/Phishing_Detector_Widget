{
  "name": "phishing-detector-widget-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "npm run compile:main && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 concurrently -k \"npm:dev:main\" \"npm:dev:renderer\" \"npm:dev:electron\"",
    "compile:main": "tsc -p tsconfig.main.json",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite --config vite.config.ts",
    "dev:electron": "node scripts/wait-and-start-electron.js",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build --config vite.config.ts",
    "build:main": "tsc -p tsconfig.main.json",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "start": "electron ."
  },
  "dependencies": {
    "electron": "^30.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.10.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "typescript": "^5.4.0",
    "vite": "^5.1.0",
    "wait-on": "^7.2.0"
  }
}

